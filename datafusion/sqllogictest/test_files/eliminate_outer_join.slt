# FULL JOIN + CAST on both sides → INNER JOIN
# CAST(NULL) = NULL → null-rejecting
query TT
explain select * from t1 full join t2 on t1.a = t2.x
  where cast(t1.b as bigint) > 10 and cast(t2.y as bigint) < 250;
----
logical_plan
01)Inner Join: t1.a = t2.x
02)--Filter: t1.b > Int32(10)
03)----TableScan: t1 projection=[a, b, c]
04)--Filter: t2.y < Int32(250)
05)----TableScan: t2 projection=[x, y, z]

query IITIIT rowsort
select * from t1 full join t2 on t1.a = t2.x
