###
### OR with same side vs cross side
###

# LEFT JOIN + OR on same nullable side → INNER JOIN
# t2.y > 150 OR t2.y < 50: when t2 is NULL, both sides are NULL → OR is NULL
query TT
explain select * from t1 left join t2 on t1.a = t2.x where t2.y > 150 or t2.y < 50;
----
logical_plan
01)Inner Join: t1.a = t2.x
02)--TableScan: t1 projection=[a, b, c]
03)--Filter: t2.y > Int32(150) OR t2.y < Int32(50)
04)----TableScan: t2 projection=[x, y, z]

query IITIIT rowsort
select * from t1 left join t2 on t1.a = t2.x where t2.y > 150 or t2.y < 50;
----
2 20 b 2 200 q

# LEFT JOIN + OR across sides → stays LEFT JOIN
# t1.b > 15 OR t2.y > 150: when t2 is NULL, t1.b > 15 can be TRUE → OR passes
query TT
explain select * from t1 left join t2 on t1.a = t2.x where t1.b > 15 or t2.y > 150;
----
logical_plan
01)Filter: t1.b > Int32(15) OR t2.y > Int32(150)
02)--Left Join: t1.a = t2.x
03)----TableScan: t1 projection=[a, b, c]
04)----TableScan: t2 projection=[x, y, z]

query IITIIT rowsort
