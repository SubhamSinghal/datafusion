# LEFT JOIN + WHERE NOT(t2.y IS NOT NULL) → stays LEFT JOIN
# NOT(IS NOT NULL(NULL)) = NOT(FALSE) = TRUE → passes filter, NOT null-rejecting
query TT
explain select * from t1 left join t2 on t1.a = t2.x where not (t2.y is not null);
----
logical_plan
01)Filter: t2.y IS NULL
02)--Left Join: t1.a = t2.x
03)----TableScan: t1 projection=[a, b, c]
04)----TableScan: t2 projection=[x, y, z]

query IITIIT rowsort
